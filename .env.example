# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_IDS=123456789,987654321

# Precios (scraping tarifaluzhora.es)
PRECIO_LUZ_FUENTE=tarifaluzhora
TARIFALUZHORA_URL=https://tarifaluzhora.es/

# LLM (Ollama)
LLM_BASE_URL=http://192.168.1.52:11434/v1/
LLM_MODEL=llama3.2
LLM_API_KEY=ollama
LLM_TIMEOUT=60

# Umbrales €/kWh: entre semana (verde <= bajo, rojo >= alto)
PRECIO_UMBRAL_BAJO=0.12
PRECIO_UMBRAL_ALTO=0.25
# Fin de semana (precios más bajos): opcional, por defecto 0.105 y 0.17
PRECIO_UMBRAL_BAJO_FINDE=0.105
PRECIO_UMBRAL_ALTO_FINDE=0.17

# Zona horaria
TIMEZONE=Europe/Madrid

# Franja horaria de notificaciones (solo se generan y envían alertas en este intervalo)
# Hora de 0 a 24: INICIO inclusive, FIN exclusive. Default 7-24 = de 7:00 a 24:00 (medianoche)
ALERTAS_HORA_INICIO=7
ALERTAS_HORA_FIN=24

# Base de datos (ruta dentro del contenedor; montar volumen)
DB_PATH=/data/precio_luz.db
